{
  "name": "@linkbeet/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "clean": "rm -rf .next",
    "lint:fix": "next lint --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "build:staging": "dotenv -e .env.staging next build",
    "build:production": "dotenv -e .env.production next build",
    "start:staging": "dotenv -e .env.staging next start",
    "start:production": "dotenv -e .env.production next start"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@linkbeet/constants": "workspace:*",
    "@linkbeet/db": "workspace:*",
    "@linkbeet/types": "workspace:*",
    "@linkbeet/ui": "workspace:*",
    "@linkbeet/utils": "workspace:*",
    "@linkbeet/validations": "workspace:*",
    "@prisma/client": "^6.6.0",
    "@tanstack/react-query": "^5.96.2",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.7.0",
    "next": "^15.3.0",
    "next-auth": "^5.0.0-beta.25",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.72.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^3.24.2",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "^16.2.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^15.3.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "prisma": "^6.6.0",
    "tailwindcss": "^4",
    "typescript": "^5.8.3"
  }
}
