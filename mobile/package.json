{
  "name": "@linkbeet/mobile",
  "version": "1.0.0",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "dev": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "eslint \"**/*.{ts,tsx}\"",
    "clean": "rm -rf node_modules/.cache",
    "lint:fix": "eslint --fix \"**/*.{ts,tsx}\"",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx}\"",
    "start:staging": "APP_ENV=staging expo start",
    "start:production": "APP_ENV=production expo start",
    "build:staging": "eas build --profile staging",
    "build:production": "eas build --profile production"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@hookform/resolvers": "^3.9.0",
    "@linkbeet/types": "workspace:*",
    "@linkbeet/validations": "workspace:*",
    "@tanstack/react-query": "^5.56.2",
    "expo": "~54.0.0",
    "expo-constants": "~18.0.13",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-status-bar": "~3.0.9",
    "react": "19.2.4",
    "react-hook-form": "^7.53.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.16.0",
    "zod": "^3.23.8",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@babel/runtime": "^7.25.0",
    "@types/react": "^19.2.14",
    "babel-preset-expo": "~54.0.10",
    "eslint": "^9.20.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-native": "^5.0.0",
    "typescript": "^5.3.3"
  }
}
