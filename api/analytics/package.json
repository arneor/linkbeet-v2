{
  "name": "@linkbeet/api-analytics",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "clean": "rm -rf dist",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --cov",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "lint:fix": "eslint --fix \"{src,apps,libs,test}/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "dev:debug": "nest start --debug --watch",
    "build:staging": "dotenv -e .env.staging nest build",
    "build:production": "dotenv -e .env.production nest build",
    "start:dev": "dotenv -e .env.development node dist/main",
    "start:staging": "dotenv -e .env.staging node dist/main",
    "start:production": "dotenv -e .env.production node dist/main"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.18",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.18",
    "@nestjs/microservices": "^11.1.18",
    "@nestjs/platform-fastify": "^11.1.18",
    "@nestjs/swagger": "^11.2.6",
    "express-basic-auth": "^1.2.1",
    "nestjs-pino": "^4.6.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@nestjs/cli": "^11.0.17",
    "@nestjs/schematics": "^11.0.10",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.15.2",
    "@types/supertest": "^7.2.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-unused-imports": "^4.4.1",
    "jest": "^30.3.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.58.0"
  }
}
