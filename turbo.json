{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "build:staging": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env.staging"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "build:production": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env.production"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "start:staging": { "cache": false },
    "start:production": { "cache": false },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "lint:fix": {
      "cache": false
    },
    "format": {
      "cache": false
    },
    "format:check": {
      "outputs": []
    },
    "test": {
      "dependsOn": [],
      "outputs": ["coverage/**"]
    },
    "test:coverage": {
      "dependsOn": [],
      "outputs": ["coverage/**"]
    },
    "clean": {
      "cache": false
    }
  }
}
