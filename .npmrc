auto-install-peers=true
strict-peer-dependencies=false

# Expo / React Native requires packages like expo-modules-core, @react-native/*,
# and other native packages to be hoisted to the root node_modules so that
# Metro bundler can resolve them. Without this, Metro cannot find transitive
# native deps that live in pnpm's virtual store.
public-hoist-pattern[]=*expo*
public-hoist-pattern[]=*react-native*
public-hoist-pattern[]=*@react-native*
public-hoist-pattern[]=*@babel*
public-hoist-pattern[]=*metro*
